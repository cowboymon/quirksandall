{
  "expo": {
    "name": "Quirks & All",
    "slug": "quirks-and-all",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": ["quirksandall", "rc-358cffb44f", "rc-961b7cef65"],
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8ECEE"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.itshypothetical.quirksandall",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Choose a photo for your pet's profile.",
        "NSCameraUsageDescription": "Take a photo for your pet's profile."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F8ECEE"
      },
      "package": "com.itshypothetical.quirksandall"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "react-native-svg",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#510000"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
