# RevenueCat — set the platform-specific keys for production (appl_… / goog_…),
# or a single shared key (e.g. a test-store key) via EXPO_PUBLIC_RC_KEY.
EXPO_PUBLIC_RC_IOS_KEY=your-revenuecat-ios-key
EXPO_PUBLIC_RC_ANDROID_KEY=your-revenuecat-android-key
EXPO_PUBLIC_RC_KEY=your-revenuecat-test-store-key
